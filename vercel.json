{
    "version": 2,
    "framework": null,
    "installCommand": "echo 'skipping install'",
    "buildCommand": "echo 'skipping build'",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "DB_CONNECTION": "mysql",
        "SESSION_DRIVER": "cookie"
    }
}