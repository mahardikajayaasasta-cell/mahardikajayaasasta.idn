{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*.css)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*.js)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*.ico)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*.png)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*.jpg)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*.svg)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "DB_CONNECTION": "mysql",
        "SESSION_DRIVER": "cookie"
    }
}