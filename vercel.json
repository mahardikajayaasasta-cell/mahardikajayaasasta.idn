{
    "version": 2,
    "framework": null,
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/favicon\\.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/(.*\\.(css|js|png|jpg|jpeg|svg|gif|woff|woff2|ttf|eot|map))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Sistem Absensi",
        "APP_ENV": "production",
        "APP_KEY": "base64:bYHAyfIyyQSrPm9vwTabzIgQ3gV8jQrgP5GicpjMQFo=",
        "APP_DEBUG": "true",
        "APP_URL": "https://mahardikajayaasasta-idn.vercel.app",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "DB_CONNECTION": "mysql",
        "SESSION_DRIVER": "cookie",
        "SESSION_SECURE_COOKIE": "true",
        "FILESYSTEM_DISK": "cloudinary"
    }
}