{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "^/$",
            "dest": "/api/index.php"
        },
        {
            "src": "^/index\\.php(.*)$",
            "dest": "/api/index.php"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:UzO1P98W4lU+j66hH+hO5Ww0Q5hBzU2Y5Pqk5l5T8Wc=",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "DB_CONNECTION": "mysql",
        "SESSION_DRIVER": "cookie"
    }
}